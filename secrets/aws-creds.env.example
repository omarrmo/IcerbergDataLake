# Copy this file to secrets/aws-creds.env (which is gitignored) and fill in real values.
# Generate a fresh key in AWS Console -> IAM -> Users -> <user> -> Security credentials.
#
# DO NOT commit the populated file. DO NOT paste these values into chat.

AWS_ACCESS_KEY_ID=AKIA__REPLACE_ME__
AWS_SECRET_ACCESS_KEY=__REPLACE_ME__
AWS_REGION=eu-central-1
AWS_DEFAULT_REGION=eu-central-1
