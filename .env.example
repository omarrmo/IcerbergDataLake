# Copy this file to .env and fill in real values for local-only overrides.
# This file is committed; .env is gitignored. Do NOT put secrets here.
#
# AWS credentials live in secrets/aws-creds.env (gitignored), NOT in this file.

# Kind cluster name
KIND_CLUSTER_NAME=iceberg

# AWS S3 bucket + region (non-secret config)
S3_BUCKET=omarrmo-iceberg-datalake-bucket-396510133177-eu-central-1-an
AWS_REGION=eu-central-1

# Custom Spark image tag (built by images/spark/build.sh)
SPARK_IMAGE=iceberg-spark:3.5.6

# Hostname suffix for ingress. localtest.me always resolves to 127.0.0.1.
INGRESS_DOMAIN=localtest.me
