# Local environment + secrets (NEVER commit)
.env
.env.local
secrets/*.env
secrets/*.yaml
!secrets/*.example
!secrets/*.example.*
!secrets/create.sh
!secrets/README.md

# Generated / cached kubeconfigs
*.kubeconfig
kubeconfig

# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class
**/__pycache__/
**/*.py[cod]
**/*$py.class

# macOS Finder files
.DS_Store
**/.DS_Store
